---
import SEO from './SEO.astro';

import '../styles/global.css'; 

interface Props {
  title?: string;
  description?: string;
  image?: string;
  businessInfo?: BusinessInfo;
}

const { title, description, image, businessInfo} = Astro.props;
---


<head>
    <meta charset="utf-8"/>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    
    <SEO title={title} description={description} image={image}  businessInfo={businessInfo}/>
</head>